{
  "mcpServers": {
    "deepwiki": {
      "url": "https://mcp.deepwiki.com/mcp",
      "type": "http"
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ]
    },
    "browser-tools": {
      "command": "npx",
      "args": [
        "@agentdeskai/browser-tools-mcp@latest"
      ]
    },
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest",
        "--extension"
      ],
      "env": {
        "PLAYWRIGHT_MCP_EXTENSION_TOKEN": "KrWvAZiAME3XR6nzY161UqVyl4iIXN9Ihbe_g-i-WaA"
      }
    },
    "memvault": {
      "command": "/opt/homebrew/bin/uv",
      "args": [
        "run",
        "--no-project",
        "--with",
        "mcp>=1.0",
        "--with",
        "httpx>=0.27",
        "python3",
        "/Users/joneshong/workshop/mcp/memvault/server.py"
      ],
      "env": {
        "CORE_API_URL": "http://localhost:8801",
        "MEMVAULT_SPACE_ID": "default",
        "PYTHONIOENCODING": "utf-8"
      }
    }
  }
}